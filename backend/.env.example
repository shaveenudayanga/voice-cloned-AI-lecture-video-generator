# LectureVoice Backend — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Application ───────────────────────────────────────────────────────────────
APP_VERSION=0.1.0
# web (browser download) or desktop (Tauri save-to-folder). See §1.1 / ADR-0007.
DEPLOYMENT_MODE=web
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Server-wide API key. Clients must send this in X-API-Key header.
# Phase 1: single key. Phase 2+: per-user DB-backed keys (see core/security.py TODO).
API_KEY=change-me-before-deploy

# CORS origins — comma-separated list, no wildcards in production
CORS_ORIGINS=["http://localhost:3000"]

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://lecturevoice:lecturevoice@postgres:5432/lecturevoice

# ── Valkey (Celery broker) ────────────────────────────────────────────────────
VALKEY_URL=redis://valkey:6379/0

# ── Object Storage (SeaweedFS S3-compatible) ──────────────────────────────────
STORAGE_ENDPOINT_URL=http://seaweedfs:8333
STORAGE_ACCESS_KEY=lecturevoice
STORAGE_SECRET_KEY=lecturevoice
STORAGE_BUCKET=lecturevoice
STORAGE_REGION=us-east-1

# ── File Upload Limits ────────────────────────────────────────────────────────
MAX_UPLOAD_BYTES=52428800  # 50 MB

# ── LLM ───────────────────────────────────────────────────────────────────────
# gemini (default) or ollama (local, zero-API)
LLM_PROVIDER=gemini
# Required when LLM_PROVIDER=gemini. Integration tests skip gracefully when absent.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-vl:7b

# ── TTS Engine ────────────────────────────────────────────────────────────────
# f5 (default, CC-BY-NC-4.0) or xtts (CPML fallback)
TTS_ENGINE=f5

# ── GPU / VRAM ────────────────────────────────────────────────────────────────
# Set to 4.0 on RTX 3050 Ti / other 4 GB VRAM devices. At <8 GB, the GPU worker
# alternates between F5-TTS and Whisper rather than loading both simultaneously.
VRAM_BUDGET_GB=12.0

# ── Whisper ───────────────────────────────────────────────────────────────────
# tiny | base | small | medium | large-v3
# base is sufficient for clean 60-second recordings.
WHISPER_MODEL_SIZE=base

# ── Celery ────────────────────────────────────────────────────────────────────
# Set to true to run tasks synchronously in tests.
CELERY_TASK_ALWAYS_EAGER=false

# ── Observability ─────────────────────────────────────────────────────────────
# stdout (dev) or otlp (production collector)
OTEL_EXPORTER=stdout
# Required when OTEL_EXPORTER=otlp
OTEL_ENDPOINT=

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
